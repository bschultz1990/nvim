{
  "auto_command": {
    "body": [
      "vim.api.nvim_create_autocmd(\"${1:event}\", {",
      "  desc = \"${2:}\",",
      "  pattern = \"*\", -- filetype",
      "  group = vim.api.nvim_create_augroup(\"${3:groupname}\", { clear = true }),",
      "  callback = function(${4:opts})",
      "    ${0:}",
      "  end,",
      "})"
    ],
    "prefix": "auto_command"
  },
  "config": {
    "body": "vim.fn.stdpath('config') $0",
    "prefix": "configpath"
  },
  "config = function": {
    "body": [
      "config = function(${1:opts})",
      "  ${0}",
      "end"
    ],
    "prefix": "config = function"
  },
  "user_command": {
    "body": [
      "vim.api.nvim_create_user_command(\"${1:name}\", function()",
      "  ${3:}",
      "end, { desc = \"${2:flowery description here}\", nargs = 0 })"
    ],
    "description": "Create Neovim User Command",
    "prefix": "user_command"
  },
  "vim.keymap": {
    "body": "vim.keymap.set('${1:mode}', '${2:key_combo}', '${3:action}', { desc = \"$0\" })",
    "prefix": "vim.keymap"
  },
  "vim.pack.add": {
    "body": [
      "vim.pack.add({",
      "    {",
      "    src = 'https://github.com/${1:}',",
      "    -- version = vim.version.range('${5:1.x}'),",
      "    -- load = false,",
      "    },",
      "    -- { src = 'https://github.com/' },",
      "    })",
      "",
      "require('${3:plugin_name}').setup({",
      "    ${4:}",
      "    })"
    ],
    "prefix": "vim.pack.add"
  }
}