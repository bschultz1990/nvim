{
  "b": {
    "body": "<b>$1</b>$0",
    "prefix": "b"
  },
  "caution": {
    "body": "> ⚠️ **$1** $0",
    "prefix": "caution"
  },
  "checkbox": {
    "body": "<div> <input type=\"checkbox\" id=\"$1\"> <label for=\"$1\"><b>$2:</b> ${0:}</label> </div>",
    "prefix": "checkbox"
  },
  "codeblock": {
    "body": [
      "```${1:language}",
      "$0",
      "```"
    ],
    "prefix": "codeblock"
  },
  "dropcheck": {
    "body": [
      "<details>",
      "    <summary><input type=\"checkbox\" id=\"${1:}\"> <label for=\"$1\">$2: ${3:flavor text} </label> </summary>",
      "",
      "${4:consummate details}",
      "</details>"
    ],
    "prefix": "dropcheck"
  },
  "dropdown": {
    "body": [
      "<details>",
      "    <summary>$1</summary>",
      "$0",
      "</details>"
    ],
    "prefix": "dropdown"
  },
  "img": {
    "body": "![${1:title}](${2:image})",
    "prefix": "img"
  },
  "link": {
    "body": "[${1:title}](<${2:url}>)",
    "prefix": "link"
  },
  "note": {
    "body": "> ℹ️ **$1** $0",
    "prefix": "note"
  },
  "remember": {
    "body": "> 💭 **$1** $0",
    "prefix": "remember"
  },
  "video": {
    "body": [
      "<video controls width=\"500\">",
      "    <source src=\"${1:}\" type=\"video/webm\" />",
      "</video>"
    ],
    "prefix": "video"
  },
  "warning": {
    "body": "> ❗ **$1** $0",
    "prefix": "warning"
  }
}