{
  "exist_directory": {
    "body": [
      "if ! [ -d ${1:directory_path} ]; then",
      "  mkdir $1",
      "fi"
    ],
    "prefix": "exist_directory"
  },
  "hashbang": {
    "body": [
      "#! /usr/bin/bash",
      "$0"
    ],
    "prefix": "hashbang"
  },
  "requirements": {
    "body": "if ! requirements ${1:\"app1\" \"app2\"}; then return; fi",
    "prefix": "requirements"
  },
  "source": {
    "body": [
      "SCRIPT_DIR=\"\\$(cd \"\\$(dirname \"\\${BASH_SOURCE[0]}\")\" && pwd)\"",
      "source \"\\$SCRIPT_DIR/$1\""
    ],
    "prefix": "import_require"
  }
}