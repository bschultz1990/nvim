{
  "exist_directory": {
    "body": [
      "if ! [ -d ${1:directory_path} ]; then",
      "  mkdir $1",
      "fi"
    ],
    "prefix": "exist_directory"
  },
  "requirements": {
    "prefix": "requirements",
    "body": "if ! requirements ${1:\"app1\" \"app2\"}; then return; fi"
  },
  "source": {
    "prefix": "import_require",
    "body": [
      "SCRIPT_DIR=\"\\$(cd \"\\$(dirname \"\\${BASH_SOURCE[0]}\")\" && pwd)\"",
      "source \"\\$SCRIPT_DIR/$1\""
    ]
  }
}
